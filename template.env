# ============================================
# Environment Variables Template
# ============================================
# This file lists all environment variables used in the project.
# Copy this file to .env (backend) or tracker-frontend/.env (frontend) and fill in your actual values.
# NEVER commit .env files with actual secrets to version control.
# ============================================

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Location: tracker-backend/.env
# ============================================

# Application Environment
NODE_ENV=
PORT=

# Database Configuration
# Use either MONGODB_URI or MONGO_URI (both are supported)
MONGODB_URI=
MONGO_URI=

# JWT Authentication
JWT_SECRET=
JWT_EXPIRE=

# Email Configuration (for notifications)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

# Alternative SMTP Configuration (if not using EMAIL_SERVICE)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_NAME=
FROM_EMAIL=

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Location: tracker-frontend/.env
# ============================================

# API Configuration
VITE_API_URL=
VITE_APP_NAME=

# ============================================
# NOTES
# ============================================
# 1. Backend .env should be placed in: tracker-backend/.env
# 2. Frontend .env should be placed in: tracker-frontend/.env
# 3. All .env files are automatically excluded from git via .gitignore
# 4. Never commit actual secrets to version control
# 5. For production, use secure environment variable management (e.g., AWS Secrets Manager, Azure Key Vault)
# ============================================
